# Wild Wanderers marketing site — environment variables
# Copy to .env.local for local dev. Never commit .env.local (.env* is gitignored).

# --- Resend + Slack: the join inquiry notifications (already in use) ---
RESEND_API_KEY=
JOIN_INBOX=hello@wildwanderers.com
JOIN_FROM=Wild Wanderers <onboarding@resend.dev>
SLACK_WEBHOOK_URL=

# --- Supabase: read-only access to the Trailhead Library ---
# The SAME values as the app's Supabase project. The marketing site reads
# published, public posts through the public anon key only. NEVER add the
# service role key here: a public site must not hold a key that bypasses RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
